# Web (apps/web)
NEXT_PUBLIC_AUDIO_SUITE_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Docker Compose host ports
AUDIO_SUITE_WEB_PORT=3000
AUDIO_SUITE_WORKER_PORT=8000
AUDIO_SUITE_WORKER_PUBLIC_URL=http://localhost:8000

# Worker (apps/worker)
AUDIO_SUITE_JOB_ROOT=/tmp/audio-suite
AUDIO_SUITE_ARTIFACT_TTL_SECONDS=3600
AUDIO_SUITE_MAX_DOWNLOAD_BYTES=536870912
AUDIO_SUITE_CLEANUP_INTERVAL_SECONDS=60
# Allow browser calls from your deployed web origin (regex)
AUDIO_SUITE_CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?|https?://[a-z0-9.-]+(:\d+)?
